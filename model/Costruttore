from dataclasses import dataclass

@dataclass
class Costruttore:
    constructorId:int
    constructorRef:str
    name:str
    nationality:str
    url:str

    def __eq__(self, other):
        return self.constructorId==other.constructorId

    def __hash__(self):
        return self.constructorId

    def __str__(self):
        return self.constructorRef
